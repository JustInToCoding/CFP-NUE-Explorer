# Set to true to use mock data (no API token needed)
VITE_USE_MOCK=true

# Real API token — only needed when VITE_USE_MOCK=false
VITE_CFP_API_TOKEN=your_api_token_here

# Override API base URL to call the CFP API directly (bypasses the Vite proxy).
# Set this to test whether the API supports CORS from the browser.
# If you see a CORS error in the console, the proxy is still needed.
# VITE_CFP_API_BASE=https://api.cfp.coolfarm.org

# FAOSTAT credentials — only needed for the Global N Context page
# Register at https://www.fao.org/faostat/
VITE_FAOSTAT_USERNAME=your_faostat_username
VITE_FAOSTAT_PASSWORD=your_faostat_password
